# ============================================================
# Internet Banking MVP - Environment Variables (Sample)
# Copy to .env and adjust values for your local environment.
# 초기 설정 방법: docs/monitoring/UNIFIED_MONITORING_GUIDE.md § 최초 실행 전 필수 설정
# ============================================================

# ---- Spring ----
SPRING_PROFILES_ACTIVE=local
JPA_DDL_AUTO=update

# ---- Host Ports (외부 노출용. 충돌 시 변경) ----
CUSTOMER_DB_PORT=5432
DEPOSIT_DB_PORT=5433
LOAN_DB_PORT=5434
PAYMENT_DB_PORT=5435
MASTER_DB_PORT=5436
AI_DB_PORT=5437
COMMON_DB_PORT=5438
REDIS_PORT=6379
KAFKA_PORT=9092
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERTMANAGER_PORT=9095
BLACKBOX_PORT=9115
WINDOWS_EXPORTER_PORT=9182
KAFKA_EXPORTER_KFTC_PORT=9308
KAFKA_EXPORTER_BOK_PORT=9309
KAFKA_EXPORTER_INTERNAL_PORT=9310

# ---- Service App Ports ----
GATEWAY_APP_PORT=8080
CUSTOMER_APP_PORT=8081
DEPOSIT_APP_PORT=8082
LOAN_APP_PORT=8083
PAYMENT_APP_PORT=8084
MASTER_APP_PORT=8085
AI_APP_PORT=8086
CONSULTATION_APP_PORT=8087
AIGATEWAY_APP_PORT=8088
AUTO_LOAN_REVIEW_APP_PORT=8086
LANGFUSE_PORT=3001
LOKI_PORT=3100
# 서비스 로그 파일 저장 경로 (Promtail이 읽는 경로와 일치해야 함)
LOG_DIR=C:/logs/internet-banking
PHOENIX_PORT=6006
PHOENIX_GRPC_PORT=4317
# Phoenix 계측 활성화 (true/false)
PHOENIX_ENABLED=false
PHOENIX_GRPC_ENDPOINT=http://localhost:4317
# Java OTel Agent (auto-loan-review, ai-service)
# JVM 실행 시 -javaagent:opentelemetry-javaagent.jar 추가
# 다운로드: https://github.com/open-telemetry/opentelemetry-java-instrumentation/releases
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# ---- customer-service DB ----
CUSTOMER_DB_NAME=customer_db
CUSTOMER_DB_USER=customer
CUSTOMER_DB_PASSWORD=customer

# ---- deposit-service DB ----
DEPOSIT_DB_NAME=deposit_db
DEPOSIT_DB_USER=deposit
DEPOSIT_DB_PASSWORD=deposit

# ---- loan-service DB ----
LOAN_DB_NAME=loan_db
LOAN_DB_USER=loan
LOAN_DB_PASSWORD=loan

# ---- payment-service DB ----
PAYMENT_DB_NAME=payment_db
PAYMENT_DB_USER=payment
PAYMENT_DB_PASSWORD=payment

# ---- master-service DB ----
MASTER_DB_NAME=master_db
MASTER_DB_USER=master
MASTER_DB_PASSWORD=master

# ---- ai-service DB ----
AI_DB_NAME=ai_db
AI_DB_USER=ai
AI_DB_PASSWORD=ai

# ---- common account DB (공통 계좌 마스터. loan-service가 먼저 채택, 추후 deposit 전환) ----
COMMON_DB_NAME=common_db
COMMON_DB_USER=common
COMMON_DB_PASSWORD=common

# ---- Langfuse DB ----
LANGFUSE_DB_PORT=5438
LANGFUSE_DB_NAME=langfuse_db
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse
# 운영 환경에서는 반드시 변경 (openssl rand -base64 32)
LANGFUSE_SECRET=langfuse-secret-change-in-prod
LANGFUSE_SALT=langfuse-salt-change-in-prod
# Langfuse API Keys (프로젝트 Settings → API Keys에서 발급)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3001

# ---- Redis ----
# docker-compose로 서비스를 컨테이너로 띄우는 경우 compose 서비스명 사용.
# 호스트에서 직접 bootRun 할 때는 localhost 로 덮어쓸 것.
REDIS_HOST=redis

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- Alertmanager ----
# Slack Incoming Webhook URL (Grafana → Alerting → Contact points → Slack-DM 에서 복사)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# healthchecks.io 핑 URL (https://healthchecks.io 가입 후 체크 생성 시 발급)
HEALTHCHECKS_PING_URL=https://hc-ping.com/[UUID]

# ---- LLM API Keys ----
# consultation-service (OpenAI) — https://platform.openai.com/api-keys
CONSULTATION_OPENAI_API_KEY=
# auto-loan-review (Gemini) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# review-ai-gateway (Claude) — https://console.anthropic.com
CLAUDE_API_KEY=

# ---- Swagger / OpenAPI ----
# 운영 환경에서는 false 권장. 로컬·개발 환경 기본 true.
SWAGGER_ENABLED=true
# 접속 URL (서비스별)
#   customer-service : http://localhost:8081/swagger-ui.html
#   deposit-service  : http://localhost:8082/swagger-ui.html
#   loan-service     : http://localhost:8083/swagger-ui.html
#   payment-service  : http://localhost:8084/swagger-ui.html
#   master-service   : http://localhost:8085/swagger-ui.html
# OpenAPI 스펙(JSON)
#   http://localhost:<port>/v3/api-docs
