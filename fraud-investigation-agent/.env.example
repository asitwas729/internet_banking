# Fraud Investigation Agent — 환경변수 예시
# 이 파일을 .env 로 복사해 값을 채운다. .env 는 절대 커밋하지 않는다.

# --- LLM provider ---------------------------------------------------------
# openai | anthropic | mock  (기본 mock — 실제 API 호출 없음)
TRIAGE_LLM_PROVIDER=mock

# 2티어 모델 덮어쓰기(선택). 미설정 시 provider 기본값:
#   openai    light=gpt-4o-mini      heavy=gpt-4o
#   anthropic light=claude-haiku-4-5 heavy=claude-sonnet-4-6
# TRIAGE_LLM_MODEL_LIGHT=
# TRIAGE_LLM_MODEL_HEAVY=

# --- API 키 (env 만! 코드·깃 금지) ---------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- 도구 실연결 (Stage 7, 선택) -----------------------------------------
# 실 백엔드를 칠 도구 목록(쉼표). 현재 get_auth_events 만 지원. 미설정 시 전부 목.
# TRIAGE_REAL_TOOLS=get_auth_events
# TRIAGE_BACKEND_URL=http://localhost:8081        # customer-service
# TRIAGE_INTERNAL_TOKEN=                          # 직원 JWT (/internal 직원 역할 보호)

# --- Langfuse (선택, 셀프호스팅 전제) -------------------------------------
# LANGFUSE_ENABLED=false
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
