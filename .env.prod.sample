# =============================================================================
# 운영 환경변수 템플릿 — .env.prod 를 만들어 Oracle 서버에 두고 절대 커밋 금지
#
# 사용:
#   cp .env.prod.sample .env.prod
#   vi .env.prod    # 실제 값 채우기
#   scp .env.prod  ubuntu@<oracle-ip>:~/app/.env.prod   # 1회 전송
# =============================================================================

# ── GHCR 이미지 ──────────────────────────────────────────────────────────
# GitHub 사용자/조직명 (예: Fast-Campus-Reboot-Campus)
GITHUB_OWNER=

# 이미지 태그 (기본 latest, CI/CD 에서 특정 SHA 로 덮어쓰기)
CUSTOMER_IMAGE_TAG=latest
DEPOSIT_IMAGE_TAG=latest
LOAN_IMAGE_TAG=latest
PAYMENT_IMAGE_TAG=latest
MASTER_IMAGE_TAG=latest
AI_IMAGE_TAG=latest
AUTO_REVIEW_IMAGE_TAG=latest
REVIEW_AIGW_IMAGE_TAG=latest
GATEWAY_IMAGE_TAG=latest
API_GATEWAY_IMAGE_TAG=latest
CONSULTATION_IMAGE_TAG=latest
DEPOSIT_API_IMAGE_TAG=latest
DATA_TOOLS_IMAGE_TAG=latest

# ── 외부 노출 포트 ────────────────────────────────────────────────────────
GATEWAY_PUBLIC_PORT=8080

# ── DB ────────────────────────────────────────────────────────────────────
CUSTOMER_DB_NAME=customer_db
CUSTOMER_DB_USER=customer
CUSTOMER_DB_PASSWORD=__CHANGE_ME__

DEPOSIT_DB_NAME=deposit_db
DEPOSIT_DB_USER=deposit
DEPOSIT_DB_PASSWORD=__CHANGE_ME__

LOAN_DB_NAME=loan_db
LOAN_DB_USER=loan
LOAN_DB_PASSWORD=__CHANGE_ME__

PAYMENT_DB_NAME=payment_db
PAYMENT_DB_USER=payment
PAYMENT_DB_PASSWORD=__CHANGE_ME__

MASTER_DB_NAME=master_db
MASTER_DB_USER=master
MASTER_DB_PASSWORD=__CHANGE_ME__

AI_DB_NAME=ai_db
AI_DB_USER=ai
AI_DB_PASSWORD=__CHANGE_ME__

# ── 인증/시크릿 ──────────────────────────────────────────────────────────
# 32자 이상 권장. openssl rand -base64 48 로 생성.
JWT_SECRET=__CHANGE_ME__internet-banking-jwt-secret-must-be-at-least-32-chars__

# ── 모니터링 ─────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__CHANGE_ME__

# ── 외부 API 키 (AI/RAG) ─────────────────────────────────────────────────
OPENAI_API_KEY=
VERTEX_AI_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json

# ── 공공데이터 (data-tools) ──────────────────────────────────────────────
KOREA_BANK_API_KEY=
KOSIS_API_KEY=
PUBLIC_DATA_API_KEY=
FISIS_API_KEY=
