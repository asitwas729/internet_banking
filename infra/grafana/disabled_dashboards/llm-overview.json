        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(increase(ai_agent_llm_calls_total{application=\"auto-loan-review\"}[1h]))",
          "legendFormat": "대출심사 (1h)"
        }
      ],
      "title": "대출심사 LLM 호출 (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "bfmta2uf2mebka" },
