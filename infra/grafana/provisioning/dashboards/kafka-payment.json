{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "Consumer Lag",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag) by (consumergroup, topic)",
          "legendFormat": "{{consumergroup}} / {{topic}}"
        }
      ],
      "title": "Consumer Lag (그룹별)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 1000}] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag) by (consumergroup)",
          "legendFormat": "{{consumergroup}}"
        }
      ],
      "title": "Consumer Lag 현황 (그룹별 합계)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 201,
      "title": "메시지 처리량",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        {
          "expr": "rate(kafka_topic_partition_current_offset[1m])",
          "legendFormat": "{{topic}} p{{partition}}"
        }
      ],
      "title": "토픽 메시지 처리율 (msg/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(increase(payment_kafka_consume_total{application=\"payment-service\"}[5m])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ],
      "title": "Consumer 처리 건수 (5분)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(increase(payment_outbox_publish_total{application=\"payment-service\", result=\"success\"}[5m]))",
          "legendFormat": "발행 성공"
        },
        {
          "expr": "sum(increase(payment_outbox_publish_total{application=\"payment-service\", result=\"failure\"}[5m]))",
          "legendFormat": "발행 실패"
        }
      ],
      "title": "Outbox 발행 성공 / 실패 (5분)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 202,
      "title": "Outbox 적체 / 미완료 거래",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "payment_outbox_pending{application=\"payment-service\"}",
          "legendFormat": "PENDING"
        }
      ],
      "title": "Outbox PENDING 적체 수",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 20}, {"color": "red", "value": 100}] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "payment_instruction_incomplete{application=\"payment-service\"}",
          "legendFormat": "미완료"
        }
      ],
      "title": "미완료 거래 수 (PENDING/CLEARING)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "payment_outbox_pending{application=\"payment-service\"}",
          "legendFormat": "Outbox PENDING"
        },
        {
          "expr": "payment_instruction_incomplete{application=\"payment-service\"}",
          "legendFormat": "미완료 거래"
        }
      ],
      "title": "적체 추이",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 203,
      "title": "이체 결과 / 처리시간",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(increase(payment_instruction_completed_total{application=\"payment-service\"}[5m]))",
          "legendFormat": "완료"
        },
        {
          "expr": "sum(increase(payment_instruction_failed_total{application=\"payment-service\"}[5m]))",
          "legendFormat": "실패"
        }
      ],
      "title": "이체 완료 / 실패 (5분)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "id": 10,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(payment_instruction_duration_seconds_bucket{application=\"payment-service\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(payment_instruction_duration_seconds_bucket{application=\"payment-service\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(payment_instruction_duration_seconds_bucket{application=\"payment-service\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "title": "이체 end-to-end 처리시간 (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "id": 11,
      "targets": [
        {
          "expr": "sum(increase(payment_instruction_completed_total{application=\"payment-service\"}[5m])) / (sum(increase(payment_instruction_completed_total{application=\"payment-service\"}[5m])) + sum(increase(payment_instruction_failed_total{application=\"payment-service\"}[5m])))",
          "legendFormat": "이체 성공률"
        }
      ],
      "title": "이체 성공률 (%)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 204,
      "title": "장애 / 보상 트랜잭션",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(increase(payment_compensation_total{application=\"payment-service\"}[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ],
      "title": "보상 트랜잭션 발생 (5분)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "id": 13,
      "targets": [
        {
          "expr": "sum(increase(payment_kafka_dlq_total{application=\"payment-service\"}[5m])) by (cluster)",
          "legendFormat": "DLQ {{cluster}}"
        }
      ],
      "title": "DLQ 유입 수 (5분)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "id": 14,
      "targets": [
        {
          "expr": "sum(increase(payment_idempotency_duplicate_total{application=\"payment-service\"}[5m]))",
          "legendFormat": "중복 거래 감지"
        }
      ],
      "title": "중복 거래 감지 수 (5분)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 205,
      "title": "Broker / Partition 상태",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 46 },
      "id": 15,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "kafka_brokers",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "활성 Broker 수",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 46 },
      "id": 16,
      "targets": [
        {
          "expr": "kafka_topic_partition_under_replicated_partition",
          "legendFormat": "{{topic}} p{{partition}}"
        }
      ],
      "title": "Under Replicated Partition",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 46 },
      "id": 17,
      "targets": [
        {
          "expr": "kafka_consumergroup_members",
          "legendFormat": "{{consumergroup}}"
        }
      ],
      "title": "Consumer Group 멤버 수",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "tags": ["kafka", "payment", "internet-banking"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Kafka Payment - 계좌이체 중간망",
  "uid": "kafka-payment-overview",
  "version": 1
}


