{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ],
      "title": "HTTP 요청 수 (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\", status=~\"4..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"$application\"}[1m])) * 100",
          "legendFormat": "4xx 에러율"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\", status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"$application\"}[1m])) * 100",
          "legendFormat": "5xx 에러율"
        }
      ],
      "title": "HTTP 에러율 (%)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "title": "API 응답시간 (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "JVM",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"$application\", area=\"heap\"}",
          "legendFormat": "사용 중"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"$application\", area=\"heap\"}",
          "legendFormat": "최대"
        }
      ],
      "title": "JVM Heap 메모리",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"$application\"}[1m])",
          "legendFormat": "{{action}} {{cause}}"
        }
      ],
      "title": "GC 일시정지 시간",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"$application\"}",
          "legendFormat": "활성 스레드"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"$application\"}",
          "legendFormat": "데몬 스레드"
        }
      ],
      "title": "JVM 스레드 수",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "시스템 / DB",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 7,
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"$application\"}",
          "legendFormat": "CPU 사용률"
        },
        {
          "expr": "system_cpu_usage{application=\"$application\"}",
          "legendFormat": "시스템 CPU"
        }
      ],
      "title": "CPU 사용률",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"$application\"}",
          "legendFormat": "활성"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"$application\"}",
          "legendFormat": "유휴"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"$application\"}",
          "legendFormat": "대기"
        },
        {
          "expr": "hikaricp_connections_max{application=\"$application\"}",
          "legendFormat": "최대"
        }
      ],
      "title": "DB 커넥션 풀",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 9,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(hikaricp_connections_acquire_seconds_bucket{application=\"$application\"}[1m])) by (le))",
          "legendFormat": "커넥션 획득 p95"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(hikaricp_connections_usage_seconds_bucket{application=\"$application\"}[1m])) by (le))",
          "legendFormat": "쿼리 사용 p95"
        }
      ],
      "title": "DB 쿼리 지연시간",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "인증 / 보안",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(increase(customer_login_success_total{application=\"$application\"}[5m]))",
          "legendFormat": "로그인 성공"
        },
        {
          "expr": "sum(increase(customer_login_failure_total{application=\"$application\"}[5m]))",
          "legendFormat": "로그인 실패 (전체)"
        },
        {
          "expr": "sum(increase(customer_login_failure_total{application=\"$application\", reason=\"locked\"}[5m]))",
          "legendFormat": "계정 잠금"
        },
        {
          "expr": "sum(increase(customer_login_failure_total{application=\"$application\", reason=\"bad_credentials\"}[5m]))",
          "legendFormat": "비밀번호 오류"
        }
      ],
      "title": "로그인 성공 / 실패 (5분)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "id": 11,
      "targets": [
        {
          "expr": "sum(increase(customer_jwt_invalid_total{application=\"$application\"}[5m]))",
          "legendFormat": "JWT 검증 실패"
        },
        {
          "expr": "sum(increase(customer_auth_access_denied_total{application=\"$application\"}[5m]))",
          "legendFormat": "권한 거부 (403)"
        }
      ],
      "title": "JWT 실패 / 권한 거부 (5분)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "id": 12,
      "targets": [
        {
          "expr": "sum(increase(customer_register_success_total{application=\"$application\"}[5m]))",
          "legendFormat": "회원가입 완료"
        },
        {
          "expr": "sum(increase(customer_register_failure_total{application=\"$application\", reason=\"duplicate_login_id\"}[5m]))",
          "legendFormat": "중복 아이디"
        }
      ],
      "title": "회원가입 현황 (5분)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 104,
      "title": "서버 자원 (windows_exporter / Node Exporter)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "id": 13,
      "targets": [
        {
          "expr": "(windows_logical_disk_size_bytes{volume=\"C:\"} - windows_logical_disk_free_bytes{volume=\"C:\"}) or (node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"})",
          "legendFormat": "사용 중"
        },
        {
          "expr": "windows_logical_disk_size_bytes{volume=\"C:\"} or node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}",
          "legendFormat": "전체"
        }
      ],
      "title": "Disk 사용량 (C: / /)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "id": 14,
      "targets": [
        {
          "expr": "rate(windows_net_bytes_received_total[1m]) or rate(node_network_receive_bytes_total{device!~\"lo|docker.*|br-.*|veth.*\"}[1m])",
          "legendFormat": "수신 {{nic}}{{device}}"
        },
        {
          "expr": "rate(windows_net_bytes_sent_total[1m]) or rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|br-.*|veth.*\"}[1m])",
          "legendFormat": "송신 {{nic}}{{device}}"
        }
      ],
      "title": "Network I/O",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 105,
      "title": "로그",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 46 },
      "id": 15,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{application=\"$application\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "애플리케이션 로그",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 58 },
      "id": 16,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{application=\"$application\"} |= \"ERROR\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "ERROR 로그",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "tags": ["spring-boot", "internet-banking"],
  "templating": {
    "list": [
      {
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(jvm_memory_used_bytes, application)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "application",
        "query": {
          "query": "label_values(jvm_memory_used_bytes, application)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "서비스"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Internet Banking - Service Overview",
  "uid": "internet-banking-overview",
  "version": 2
}
