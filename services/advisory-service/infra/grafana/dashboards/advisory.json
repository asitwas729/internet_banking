{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "schemaVersion": 39,
  "tags": ["loan", "advisory", "lon"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "Asia/Seoul",
  "title": "LON 심사관 어드바이저리",
  "uid": "lon-advisory",
  "version": 1,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "룰별 트리거 빈도 (rate / 5m)",
      "description": "advisory_report_published_total — rule_cd 별 시간당 발행 속도.",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (rule_cd) (rate(advisory_report_published_total[5m]))",
          "legendFormat": "{{rule_cd}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "ack 응답 분포 (누적 카운트)",
      "description": "advisory_ack_response_total — response_cd 별 누적 ack 수.",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none"
      },
      "targets": [
        {
          "expr": "sum by (response_cd) (increase(advisory_ack_response_total[24h]))",
          "legendFormat": "{{response_cd}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "미해결 리포트 누적 (gauge by severity)",
      "description": "advisory_open_reports — OPEN/VIEWED 상태 리포트 수 (severity 별).",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CRITICAL" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "WARN" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "advisory_open_reports",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CRITICAL 게이트 차단 추세 (rate / 5m)",
      "description": "advisory_critical_gate_blocked_total — 미해결 CRITICAL 로 약정 생성이 막힌 횟수.",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "fixed", "fixedColor": "red" } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(advisory_critical_gate_blocked_total[5m])",
          "legendFormat": "blocked",
          "refId": "A"
        }
      ]
    }
  ]
}
