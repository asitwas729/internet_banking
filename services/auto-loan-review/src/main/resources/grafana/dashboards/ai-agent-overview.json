{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "AI Agent Overview",
  "uid": "ai-agent-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "에이전트 성공률 (Track별)",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(track, outcome) (rate(ai_agent_runs_total{application=\"auto-loan-review\"}[5m]))",
          "legendFormat": "{{track}} / {{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Agent P95 지연 (초)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "thresholdsStyle": { "mode": "line" } } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by(le, track) (rate(ai_agent_latency_seconds_bucket{application=\"auto-loan-review\"}[5m])))",
          "legendFormat": "P95 {{track}}"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "color": "green", "value": null },
          { "color": "red",   "value": 30 }
        ]
      }
    },
    {
      "id": 3,
      "title": "LLM RPM 소비",
      "type": "timeseries",
      "gridPos": { "x": 15, "y": 0, "w": 9, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "ai_agent_rpm_remaining{application=\"auto-loan-review\"}",
          "legendFormat": "잔여 RPM"
        }
      ]
    },
    {
      "id": 4,
      "title": "일별 RPD 소비",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 4, "h": 6 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1500,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red",    "value": 1400 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1500 - ai_agent_rpd_remaining{application=\"auto-loan-review\"}",
          "legendFormat": "오늘 사용 RPD"
        }
      ]
    },
    {
      "id": 5,
      "title": "도구 호출 분포",
      "type": "barchart",
      "gridPos": { "x": 4, "y": 8, "w": 10, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(tool_name, status) (increase(ai_agent_tool_calls_total{application=\"auto-loan-review\"}[1h]))",
          "legendFormat": "{{tool_name}} [{{status}}]"
        }
      ]
    },
    {
      "id": 6,
      "title": "Fallback 사유 분포",
      "type": "barchart",
      "gridPos": { "x": 14, "y": 8, "w": 10, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(reason) (increase(ai_agent_fallback_total{application=\"auto-loan-review\"}[1h]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "추정 비용 누적 (USD/day)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 14, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(ai_agent_cost_usd_total{application=\"auto-loan-review\"}[1d]))",
          "legendFormat": "USD/day"
        }
      ]
    },
    {
      "id": 8,
      "title": "Disagreement 건수 (1h)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 14, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "red",    "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(ai_agent_disagreement_total{application=\"auto-loan-review\"}[1h]))",
          "legendFormat": "불일치"
        }
      ]
    }
  ]
}
